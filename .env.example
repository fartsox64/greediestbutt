# -----------------------------------------------------------------------
# Copy this file to .env and fill in the values before running:
#   docker compose up -d --build
# -----------------------------------------------------------------------

# Public URL of the site — used for Steam OpenID login redirects.
# Must exactly match the URL your browser uses to reach the app.
APP_URL=https://yourdomain.com

# Long random string used to sign login JWTs.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=changeme-set-this-to-a-long-random-string

# Steam Web API key — needed to resolve player names and avatars.
# Get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Postgres password (default: postgres — change in production)
DB_PASSWORD=postgres

# Host port to expose the app on (default: 80)
PORT=80

# -----------------------------------------------------------------------
# Leaderboard version detection patterns (optional)
# Regex patterns matched against Steam leaderboard names. Leave blank to
# use built-in defaults. Only set these if the defaults misidentify boards
# for your region — run GET /api/admin/leaderboard-discovery to inspect
# the actual Steam names first.
# -----------------------------------------------------------------------
AFTERBIRTH_SCORE_PATTERN=
AFTERBIRTH_TIME_PATTERN=
AFTERBIRTH_PLUS_SCORE_PATTERN=
AFTERBIRTH_PLUS_TIME_PATTERN=
REPENTANCE_SCORE_PATTERN=
REPENTANCE_TIME_PATTERN=
REPENTANCE_PLUS_SOLO_SCORE_PATTERN=
REPENTANCE_PLUS_SOLO_TIME_PATTERN=
REPENTANCE_PLUS_COOP_SCORE_PATTERN=
REPENTANCE_PLUS_COOP_TIME_PATTERN=
