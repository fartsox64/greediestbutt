DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/greediest_butt

# Optional: Steam Web API key for resolving player names and avatars.
# Get one at https://steamcommunity.com/dev/apikey
# Without this, entries will display Steam IDs instead of player names, and avatars won't load.
STEAM_API_KEY=

# Base URL the browser uses to reach the app. Used for Steam OpenID redirects.
# In development this is the Vite dev server; in production it's your public domain.
APP_URL=http://localhost:5173

# Secret key used to sign session JWTs. Must be set to a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=changeme-set-SESSION_SECRET-in-production

# Per-(version, sort_type) regex patterns matched against Steam leaderboard names.
# Each pattern must uniquely identify exactly one leaderboard type.
# Run GET /api/admin/leaderboard-discovery to inspect actual Steam names, then
# calibrate these patterns accordingly.
# Defaults assume time boards contain the word "time" in their name.
AFTERBIRTH_SCORE_PATTERN=(?i)afterbirth(?!\+|plus|_plus)(?!.*\btime\b)
AFTERBIRTH_TIME_PATTERN=(?i)afterbirth(?!\+|plus|_plus).*\btime\b
AFTERBIRTH_PLUS_SCORE_PATTERN=(?i)afterbirth(\+|plus|_plus)(?!.*\btime\b)
AFTERBIRTH_PLUS_TIME_PATTERN=(?i)afterbirth(\+|plus|_plus).*\btime\b
REPENTANCE_SCORE_PATTERN=(?i)repentance(?!\+|plus|_plus)(?!.*\btime\b)
REPENTANCE_TIME_PATTERN=(?i)repentance(?!\+|plus|_plus).*\btime\b
REPENTANCE_PLUS_SOLO_SCORE_PATTERN=(?i)repentance(\+|plus|_plus)(?!.*(co.?op))(?!.*\btime\b)
REPENTANCE_PLUS_SOLO_TIME_PATTERN=(?i)repentance(\+|plus|_plus)(?!.*(co.?op)).*\btime\b
REPENTANCE_PLUS_COOP_SCORE_PATTERN=(?i)repentance(\+|plus|_plus).*(co.?op)(?!.*\btime\b)
REPENTANCE_PLUS_COOP_TIME_PATTERN=(?i)repentance(\+|plus|_plus).*(co.?op).*\btime\b
